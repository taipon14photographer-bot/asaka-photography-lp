---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteContent, siteLinks } from "../data/siteContent";

const { hero, works, about, voice, finalCta, social } = siteContent;
---

<BaseLayout>
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero__media">
      <picture>
        <source media="(max-width: 719px)" srcset={hero.image.mobile} type="image/jpeg" />
        <img
          src={hero.image.desktop}
          alt={hero.image.alt}
          width={1800}
          height={1200}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </picture>
      <div class="hero__overlay">
        <h1 id="hero-title" aria-label={hero.title}>
          {hero.titleLines.map((line) => <span>{line}</span>)}
        </h1>
      </div>
    </div>
    <div class="hero__content">
      <div class="hero__actions">
        <a class="button" href={siteLinks.line} target="_blank" rel="noreferrer">LINEで撮影相談する</a>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="top-works-title">
    <div class="section-head section-head--wide" data-animate="fade-up">
      <p class="section-kicker">Works</p>
      <h2 id="top-works-title">{works.title}</h2>
      <p class="lead">{works.body}</p>
    </div>
    <div class="page-card-grid works-digest">
      {
        works.preview.map((item) => (
          <a class="page-card works-digest__item" href={`/works/#${item.slug}`} data-animate="image-reveal">
            <Image src={item.image} alt={item.alt} width={640} height={640} loading="lazy" decoding="async" style={`object-position: ${item.focus};`} />
            <div class="page-card__body">
              <p class="section-kicker">{item.label}</p>
              <h3>{item.title}</h3>
            </div>
          </a>
        ))
      }
    </div>
    <p class="section-link" data-animate="fade-up"><a href="/works/">人生の流れで写真を見る</a></p>
  </section>

  <section class="section section--paper" aria-labelledby="top-about-title">
    <div class="about-brief" data-animate="fade-up">
      <p class="section-kicker">About</p>
      <h2 id="top-about-title">{about.title}</h2>
      <div class="section-copy">
        {about.body.slice(0, 3).map((line) => <p>{line}</p>)}
      </div>
      <a class="button button--ghost" href="/about/">撮影への考え方を見る</a>
    </div>
  </section>

  <section class="section voice-section" aria-labelledby="top-voice-title">
    <div class="section-head" data-animate="fade-up">
      <p class="section-kicker">Voice</p>
      <h2 id="top-voice-title">{voice.title}</h2>
      <p class="lead">{voice.body}</p>
    </div>
    <div class="voice-grid">
      {
        voice.items.map((item) => (
          <article class="voice-card" data-animate="fade-up">
            <div class="voice-card__meta">
              <span class="voice-card__stars" aria-label="5つ星評価">{item.rating}</span>
              <span class="voice-card__genre">{item.genre}</span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.quote}</p>
          </article>
        ))
      }
    </div>
    <div class="voice-section__footer" data-animate="fade-up">
      <p class="voice-section__note">{voice.note}</p>
      <div class="voice-section__cta">
        <p>
          <strong>{voice.cta.title}</strong>
          <span>{voice.cta.body}</span>
        </p>
        <a class="button button--ghost" href={siteLinks.line} target="_blank" rel="noreferrer">LINEで相談する</a>
      </div>
    </div>
  </section>

  <section class="section section--beige" aria-labelledby="top-price-title">
    <div class="section-head" data-animate="fade-up">
      <p class="section-kicker">Price</p>
      <h2 id="top-price-title">プランと料金を、先に確認できます。</h2>
      <p class="lead">Weddingは比較表で、Maternity / Newborn / Familyも料金ページにまとめています。</p>
      <a class="button" href="/price/">プランと料金を確認する</a>
    </div>
  </section>

  <section class="section section--paper" aria-labelledby="top-social-title">
    <div class="section-head" data-animate="fade-up">
      <p class="section-kicker">SNS</p>
      <h2 id="top-social-title">{social.title}</h2>
      <p class="lead">{social.body}</p>
    </div>
    <div class="social-grid">
      {
        social.links.map((link) => (
          <a class="social-card" href={link.href} target="_blank" rel="noreferrer" data-animate="fade-up">
            <span class="social-card__icon" aria-hidden="true">
              {
                link.label === "Instagram" && (
                  <svg viewBox="0 0 24 24" role="img">
                    <rect x="4.5" y="4.5" width="15" height="15" rx="4.2" />
                    <circle cx="12" cy="12" r="3.4" />
                    <circle cx="16.4" cy="7.7" r="0.9" />
                  </svg>
                )
              }
              {
                link.label === "note" && (
                  <svg viewBox="0 0 24 24" role="img">
                    <rect x="4.5" y="4.5" width="15" height="15" rx="3.2" />
                    <path d="M9 15.8V8.2h1.9l3.2 4.5V8.2H16v7.6h-1.9l-3.2-4.5v4.5H9z" fill="currentColor" stroke="none" />
                  </svg>
                )
              }
              {
                link.label === "LINE" && (
                  <svg viewBox="0 0 24 24" role="img">
                    <path d="M12 5.2c4.4 0 8 2.8 8 6.3 0 3.4-3.4 6.1-7.6 6.3l-3.5 2.1.7-2.6C6.3 16.4 4 14.1 4 11.5c0-3.5 3.6-6.3 8-6.3z" />
                    <path d="M8.4 10.4v2.6h1.8M11.4 10.4v2.6M13 10.4l1.7 2.6v-2.6M17 10.4h-1.6v2.6H17M15.5 11.7h1.2" />
                  </svg>
                )
              }
            </span>
            <span class="social-card__label">{link.label}</span>
            <strong>{link.text}</strong>
          </a>
        ))
      }
    </div>
  </section>

  <section class="cta-section" aria-labelledby="top-contact-title">
    <div data-animate="fade-up">
      <p class="eyebrow">Contact</p>
      <h2 id="top-contact-title">{finalCta.title}</h2>
      <p>{finalCta.body}</p>
      <p>{finalCta.note}</p>
    </div>
    <div class="cta-section__actions" data-animate="fade-up">
      <a class="button" href={siteLinks.line} target="_blank" rel="noreferrer">LINEで撮影について相談する</a>
    </div>
  </section>
</BaseLayout>
