---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteContent, siteLinks } from "../data/siteContent";

const { about } = siteContent;
---

<BaseLayout title="About | ASAKA Photography" description="静岡・伊豆を中心に出張撮影を行うASAKA Photographyの朝香大樹が、撮影で大切にしていること。撮る前に、人を見るという姿勢について。">
  <section class="section section--paper" aria-labelledby="profile-title">
    <article class="profile-card profile-card--feature" data-animate="fade-up">
      <div class="profile-card__image" data-animate="image-reveal">
        <Image src={about.image.src} alt={about.image.alt} width={900} height={600} loading="eager" decoding="async" />
      </div>
      <div class="profile-card__content">
        <p class="section-kicker">{about.profile.title}</p>
        <h1 id="profile-title">{about.profile.name}</h1>
        <p class="profile-card__role">{about.profile.role}</p>
        <div class="section-copy profile-card__body">
          {about.profile.body.map((line) => <p>{line}</p>)}
        </div>
        <div class="profile-card__tags" aria-label="朝香大樹のプロフィールタグ">
          {about.profile.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </div>
    </article>
  </section>

  <section class="section" aria-labelledby="about-title">
    <div class="about-brief" data-animate="fade-up">
      <p class="eyebrow">About</p>
      <h2 id="about-title">{about.title}</h2>
      <div class="section-copy">
        {about.body.map((line) => <p>{line}</p>)}
      </div>
      <p class="lead">{about.note}</p>
      <div class="note-link-panel">
        <p>もっと詳しい撮影への考え方は、noteで発信しています。</p>
        <a class="text-link" href={siteLinks.note} target="_blank" rel="noreferrer">撮影への考え方を読む</a>
      </div>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="about-contact-title">
    <div data-animate="fade-up">
      <p class="eyebrow">Next</p>
      <h2 id="about-contact-title" class="balanced-heading">
        <span>写真を見てから、</span><span>相談しても大丈夫です。</span>
      </h2>
      <p>撮影の雰囲気を見たい方はWorksへ。具体的に日程や場所を相談したい方はLINEへお進みください。</p>
    </div>
    <div class="cta-section__actions" data-animate="fade-up">
      <a class="button button--light" href="/works/">Worksを見る</a>
      <a class="button button--ghost" href={siteLinks.line} target="_blank" rel="noreferrer">LINEで相談する</a>
    </div>
  </section>
</BaseLayout>
