---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteContent, siteLinks } from "../data/siteContent";

const weddingModules = import.meta.glob([
  "../assets/photos/works-gallery/wedding/*.jpg",
  "../assets/photos/works-gallery/wedding/*.JPG",
  "../assets/photos/works-gallery/wedding/*.jpeg",
  "../assets/photos/works-gallery/wedding/*.JPEG",
  "../assets/photos/works-gallery/wedding/*.png",
  "../assets/photos/works-gallery/wedding/*.PNG",
], {
  eager: true,
  import: "default",
});
const maternityModules = import.meta.glob([
  "../assets/photos/works-gallery/maternity/*.jpg",
  "../assets/photos/works-gallery/maternity/*.JPG",
  "../assets/photos/works-gallery/maternity/*.jpeg",
  "../assets/photos/works-gallery/maternity/*.JPEG",
  "../assets/photos/works-gallery/maternity/*.png",
  "../assets/photos/works-gallery/maternity/*.PNG",
], {
  eager: true,
  import: "default",
});
const newbornModules = import.meta.glob([
  "../assets/photos/works-gallery/newborn/*.jpg",
  "../assets/photos/works-gallery/newborn/*.JPG",
  "../assets/photos/works-gallery/newborn/*.jpeg",
  "../assets/photos/works-gallery/newborn/*.JPEG",
  "../assets/photos/works-gallery/newborn/*.png",
  "../assets/photos/works-gallery/newborn/*.PNG",
], {
  eager: true,
  import: "default",
});
const omiyamairiModules = import.meta.glob([
  "../assets/photos/works-gallery/omiyamairi/*.jpg",
  "../assets/photos/works-gallery/omiyamairi/*.JPG",
  "../assets/photos/works-gallery/omiyamairi/*.jpeg",
  "../assets/photos/works-gallery/omiyamairi/*.JPEG",
  "../assets/photos/works-gallery/omiyamairi/*.png",
  "../assets/photos/works-gallery/omiyamairi/*.PNG",
], {
  eager: true,
  import: "default",
});
const shichigosanModules = import.meta.glob([
  "../assets/photos/works-gallery/shichigosan/*.jpg",
  "../assets/photos/works-gallery/shichigosan/*.JPG",
  "../assets/photos/works-gallery/shichigosan/*.jpeg",
  "../assets/photos/works-gallery/shichigosan/*.JPEG",
  "../assets/photos/works-gallery/shichigosan/*.png",
  "../assets/photos/works-gallery/shichigosan/*.PNG",
], {
  eager: true,
  import: "default",
});
const familyModules = import.meta.glob([
  "../assets/photos/works-gallery/family/*.jpg",
  "../assets/photos/works-gallery/family/*.JPG",
  "../assets/photos/works-gallery/family/*.jpeg",
  "../assets/photos/works-gallery/family/*.JPEG",
  "../assets/photos/works-gallery/family/*.png",
  "../assets/photos/works-gallery/family/*.PNG",
], {
  eager: true,
  import: "default",
});

const pickImages = (modules: Record<string, unknown>, names: string[]): ImageMetadata[] => {
  const entries = Object.entries(modules) as Array<[string, ImageMetadata]>;
  return names
    .map((name) => entries.find(([path]) => path.toLowerCase().endsWith(name.toLowerCase()))?.[1])
    .filter((image): image is ImageMetadata => Boolean(image));
};

const gallerySections = [
  {
    id: "wedding",
    title: "Wedding Gallery",
    lead: "ふたりで始まる、家族の時間。光、距離感、照れた表情まで。",
    alt: "ウェディング前撮りの写真",
    images: pickImages(weddingModules, [
      "01-kuboi-wedding-91.jpg",
      "11-ikeda-18.jpg",
      "12-ikeda-20.jpg",
      "03-mori-prewedding-200.jpg",
      "02-kazuki-emiri-159.jpg",
      "05-kuboi-wedding-105.jpg",
      "15-takano-prewedding-153.jpg",
      "13-kuboi-wedding-144.jpg",
    ]),
  },
  {
    id: "maternity",
    title: "Maternity Gallery",
    lead: "まだ会えない子と、もう始まっている家族の時間。",
    alt: "マタニティフォトの写真",
    images: pickImages(maternityModules, [
      "01-arisa-165.jpg",
      "05-utsumi-70.jpg",
      "06-nakano-175.jpg",
      "02-utsumi-103.jpg",
      "04-utsumi-177.jpg",
      "03-utsumi-15.jpg",
    ]),
  },
  {
    id: "newborn",
    title: "Newborn Gallery",
    lead: "家族になったばかりの、まなざしと手の温度。",
    alt: "ニューボーンフォトの写真",
    images: pickImages(newbornModules, [
      "01-riri-66.jpg",
      "03-riri-314.jpg",
      "02-riri-160.jpg",
      "04-arii-213.jpg",
      "05-ao-birth-319.jpg",
      "06-riri-55.jpg",
      "07-riri-36.jpg",
    ]),
  },
  {
    id: "omiyamairi",
    title: "お宮参り Gallery",
    lead: "はじめて家族で祈る日。抱っこする人、見守る人、その日の空気まで。",
    alt: "お宮参りの写真",
    images: pickImages(omiyamairiModules, [
      "01-omiyamairi-148.jpg",
      "02-uryu-173.jpg",
      "03-uryu-145.jpg",
      "05-uryu-181.jpg",
      "04-uryu-147.jpg",
    ]),
  },
  {
    id: "753",
    title: "七五三 Gallery",
    lead: "少し大きくなった今を、家族みんなで見つめる日。",
    alt: "七五三の写真",
    images: pickImages(shichigosanModules, [
      "01-yuma-sena-203.jpg",
      "03-yuma-sena-194.jpg",
      "04-yuma-sena-181.jpg",
      "02-20240421-362.jpg",
      "05-20240421-394.jpg",
    ]),
  },
  {
    id: "family",
    title: "Family Gallery",
    lead: "特別な日だけではなく、何気ない日にも残したい幸せがあります。",
    alt: "家族写真",
    images: pickImages(familyModules, [
      "01-day-camp-75.jpg",
      "03-ena-224.jpg",
      "02-day-camp-139.jpg",
      "04-takagi-76.jpg",
      "05-sone-127.jpg",
      "06-20240414-458.jpg",
    ]),
  },
];

const { works } = siteContent;
---

<BaseLayout title="Works | ASAKA Photography" description="Wedding、Maternity、Newborn、お宮参り、七五三、Familyを人生導線で見られる作例ギャラリーページ。">
  <section class="page-hero" aria-labelledby="works-title">
    <div class="page-hero__copy">
      <p class="eyebrow">Works</p>
      <h1 id="works-title">{works.title}</h1>
      <p class="lead">{works.body}</p>
    </div>
  </section>

  <nav class="gallery-chip-nav" aria-label="人生の流れで見るギャラリー">
    <p>人生の流れを、写真でたどる。</p>
    <div class="gallery-chip-nav__scroller">
      {gallerySections.map((section) => <a href={`#${section.id}`}>{section.title.replace(" Gallery", "")}</a>)}
    </div>
  </nav>

  {
    gallerySections.map((section, sectionIndex) => (
      <section class="gallery-section" id={section.id} aria-labelledby={`${section.id}-title`}>
        <div class="section-head section-head--wide" data-animate="fade-up">
          <p class="section-kicker">{String(sectionIndex + 1).padStart(2, "0")}</p>
          <h2 id={`${section.id}-title`}>{section.title}</h2>
          <p class="lead">{section.lead}</p>
        </div>
        <div class="gallery-grid">
          {section.images.map((image, imageIndex) => (
            <figure class:list={["gallery-frame", imageIndex === 0 && "gallery-frame--feature"]}>
              <Image
                src={image}
                alt={`${section.alt} ${imageIndex + 1}`}
                loading={sectionIndex === 0 && imageIndex < 2 ? "eager" : "lazy"}
                decoding="async"
              />
            </figure>
          ))}
        </div>
      </section>
    ))
  }

  <section class="cta-section" aria-labelledby="works-contact-title">
    <div data-animate="fade-up">
      <p class="eyebrow">Contact</p>
      <h2 id="works-contact-title">気になる写真の雰囲気を、LINEで教えてください。</h2>
      <p>「この写真みたいに撮りたい」「場所はまだ未定」でも大丈夫です。写真を見ながら相談できます。</p>
    </div>
    <div class="cta-section__actions" data-animate="fade-up">
      <a class="button button--light" href={siteLinks.line} target="_blank" rel="noreferrer">LINEで相談する</a>
      <a class="button button--ghost" href="/price/">料金を見る</a>
    </div>
  </section>
</BaseLayout>
