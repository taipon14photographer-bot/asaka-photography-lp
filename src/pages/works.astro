  import: "default",
});
const familyModules = import.meta.glob([
  "../assets/photos/works-gallery/family/*.jpg",
  "../assets/photos/works-gallery/family/*.JPG",
  "../assets/photos/works-gallery/family/*.jpeg",
  "../assets/photos/works-gallery/family/*.JPEG",
  "../assets/photos/works-gallery/family/*.png",
  "../assets/photos/works-gallery/family/*.PNG",
], {
  eager: true,
  import: "default",
});

const pickImages = (modules: Record<string, unknown>, items: GalleryImageItem[]): GalleryImage[] => {
  const entries = Object.entries(modules) as Array<[string, ImageMetadata]>;
  return items
    .map((item) => {
      const src = entries.find(([path]) => path.toLowerCase().endsWith(item.name.toLowerCase()))?.[1];
      return src ? { src, alt: item.alt, caption: item.caption } : undefined;
    })
    .filter((image): image is GalleryImage => Boolean(image));
};

