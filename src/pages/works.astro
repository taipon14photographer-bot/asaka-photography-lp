---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteContent, siteLinks } from "../data/siteContent";

type GalleryImage = {
  src: ImageMetadata;
  alt: string;
  caption: string;
};

type GalleryImageItem = {
  name: string;
  alt: string;
  caption: string;
};

