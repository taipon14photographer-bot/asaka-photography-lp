---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteContent, siteLinks } from "../data/siteContent";

const weddingModules = import.meta.glob([
  "../assets/photos/works-gallery/wedding/*.jpg",
  "../assets/photos/works-gallery/wedding/*.JPG",
  "../assets/photos/works-gallery/wedding/*.jpeg",
  "../assets/photos/works-gallery/wedding/*.JPEG",
  "../assets/photos/works-gallery/wedding/*.png",
  "../assets/photos/works-gallery/wedding/*.PNG",
], {
  eager: true,
  import: "default",
});
const maternityModules = import.meta.glob([
  "../assets/photos/works-gallery/maternity/*.jpg",
  "../assets/photos/works-gallery/maternity/*.JPG",
  "../assets/photos/works-gallery/maternity/*.jpeg",
  "../assets/photos/works-gallery/maternity/*.JPEG",
  "../assets/photos/works-gallery/maternity/*.png",
  "../assets/photos/works-gallery/maternity/*.PNG",
], {
  eager: true,
  import: "default",
});
const newbornModules = import.meta.glob([
  "../assets/photos/works-gallery/newborn/*.jpg",
  "../assets/photos/works-gallery/newborn/*.JPG",
  "../assets/photos/works-gallery/newborn/*.jpeg",
  "../assets/photos/works-gallery/newborn/*.JPEG",
  "../assets/photos/works-gallery/newborn/*.png",
  "../assets/photos/works-gallery/newborn/*.PNG",
], {
  eager: true,
  import: "default",
});
const omiyamairiModules = import.meta.glob([
  "../assets/photos/works-gallery/omiyamairi/*.jpg",
  "../assets/photos/works-gallery/omiyamairi/*.JPG",
  "../assets/photos/works-gallery/omiyamairi/*.jpeg",
  "../assets/photos/works-gallery/omiyamairi/*.JPEG",
  "../assets/photos/works-gallery/omiyamairi/*.png",
  "../assets/photos/works-gallery/omiyamairi/*.PNG",
], {
  eager: true,
  import: "default",
});
const shichigosanModules = import.meta.glob([
  "../assets/photos/works-gallery/shichigosan/*.jpg",
  "../assets/photos/works-gallery/shichigosan/*.JPG",
  "../assets/photos/works-gallery/shichigosan/*.jpeg",
  "../assets/photos/works-gallery/shichigosan/*.JPEG",
  "../assets/photos/works-gallery/shichigosan/*.png",
  "../assets/photos/works-gallery/shichigosan/*.PNG",
], {
  eager: true,
  import: "default",
});
const familyModules = import.meta.glob([
  "../assets/photos/works-gallery/family/*.jpg",
  "../assets/photos/works-gallery/family/*.JPG",
  "../assets/photos/works-gallery/family/*.jpeg",
  "../assets/photos/works-gallery/family/*.JPEG",
  "../assets/photos/works-gallery/family/*.png",
  "../assets/photos/works-gallery/family/*.PNG",
], {
  eager: true,
  import: "default",
});

const pickImages = (modules: Record<string, unknown>, names: string[]): ImageMetadata[] => {
  const entries = Object.entries(modules) as Array<[string, ImageMetadata]>;
  return names
    .map((name) => entries.find(([path]) => path.toLowerCase().endsWith(name.toLowerCase()))?.[1])
    .filter((image): image is ImageMetadata => Boolean(image));
};

const gallerySections = [
  {
    id: "wedding",
    title: "Wedding Gallery",
    lead: "ふたりで始まる、家族の時間。光、距離感、照れた表情まで。",
    alt: "ウェディング前撮りの写真",
    images: pickImages(weddingModules, [
      "01-kuboi-wedding-91.jpg",
      "11-ikeda-18.jpg",
      "12-ikeda-20.jpg",
      "03-mori-prewedding-200.jpg",
      "02-kazuki-emiri-159.jpg",
      "05-kuboi-wedding-105.jpg",
      "15-takano-prewedding-153.jpg",
    ]),
  },
  {
    id: "maternity",
    title: "Maternity Gallery",
    lead: "まだ会えない子と、もう始まっている家族の時間。",
    alt: "マタニティフォトの写真",
    images: pickImages(maternityModules, [
      "01-arisa-165.jpg",
      "05-utsumi-70.jpg",
      "06-nakano-175.jpg",
      "02-utsumi-103.jpg",
      "04-utsumi-177.jpg",
    ]),
  },
  {
    id: "newborn",
    title: "Newborn Gallery",
    lead: "家族になったばかりの、まなざしと手の温度。",
    alt: "ニューボーンフォトの写真",
    images: pickImages(newbornModules, [
      "01-riri-66.jpg",
      "03-riri-314.jpg",
      "02-riri-160.jpg",
      "04-arii-213.jpg",
      "05-ao-birth-319.jpg",
      "06-riri-55.jpg",
      "07-riri-36.jpg",
    ]),
  },
  {
    id: "omiyamairi",
    title: "お宮参り Gallery",
    lead: "はじめて家族で祈る日。抱っこする人、見守る人、その日の空気まで。",
    alt: "お宮参りの写真",
    images: pickImages(omiyamairiModules, [
      "01-omiyamairi-148.jpg",
      "02-uryu-173.jpg",
      "03-uryu-145.jpg",
      "05-uryu-181.jpg",
      "04-uryu-147.jpg",
    ]),
  },
  {
    id: "753",
    title: "七五三 Gallery",
    lead: "少し大きくなった今を、家族みんなで見つめる日。",
    alt: "七五三の写真",
    images: pickImages(shichigosanModules, [
      "01-yuma-sena-203.jpg",
      "03-yuma-sena-194.jpg",
      "04-yuma-sena-181.jpg",
      "02-20240421-362.jpg",
      "05-20240421-394.jpg",
    ]),
  },
  {
    id: "family",
    title: "Family Gallery",
    lead: "特別な日だけではなく、何気ない日にも残したい幸せがあります。",
    alt: "家族写真",
    images: pickImages(familyModules, [
      "02-day-camp-139.jpg",
      "03-ena-224.jpg",
      "01-day-camp-75.jpg",
      "08-20240414-613.JPG",
      "07-20240414-426.JPG",
    ]),
  },
];

const { works } = siteContent;
---

<BaseLayout title="Works | ASAKA Photography" description="Wedding、Maternity、Newborn、お宮参り、七五三、Familyを人生導線で見られる作例ギャラリーページ。">
  <section class="page-hero" aria-labelledby="works-title">
    <div class="page-hero__copy">
      <p class="eyebrow">Works</p>
      <h1 id="works-title">{works.title}</h1>
      <p class="lead">{works.body}</p>
    </div>
  </section>

  <nav class="gallery-card-nav" aria-label="人生の流れで見るギャラリー">
    <div class="gallery-card-nav__grid">
      {
        gallerySections.map((section, sectionIndex) => (
          <a href={`#${section.id}`}>
            <span>{String(sectionIndex + 1).padStart(2, "0")}</span>
            <strong>{section.title.replace(" Gallery", "")}</strong>
          </a>
        ))
      }
    </div>
  </nav>

  {
    gallerySections.map((section, sectionIndex) => (
      <section class="gallery-section" id={section.id} aria-labelledby={`${section.id}-title`}>
        <div class="section-head section-head--wide" data-animate="fade-up">
          <p class="section-kicker">{String(sectionIndex + 1).padStart(2, "0")}</p>
          <h2 id={`${section.id}-title`}>{section.title}</h2>
          <p class="lead">{section.lead}</p>
        </div>
        <div class="gallery-grid">
          {section.images.map((image, imageIndex) => (
            <figure class:list={["gallery-frame", imageIndex === 0 && "gallery-frame--feature"]}>
              <button
                class="gallery-lightbox-trigger"
                type="button"
                data-lightbox-trigger
                aria-label={`${section.alt} ${imageIndex + 1}を拡大表示`}
              >
                <Image
                  src={image}
                  alt={`${section.alt} ${imageIndex + 1}`}
                  loading={sectionIndex === 0 && imageIndex < 2 ? "eager" : "lazy"}
                  decoding="async"
                />
              </button>
            </figure>
          ))}
        </div>
      </section>
    ))
  }

  <div class="gallery-lightbox" data-lightbox hidden aria-hidden="true">
    <button class="gallery-lightbox__close" type="button" data-lightbox-close aria-label="拡大表示を閉じる">閉じる</button>
    <button class="gallery-lightbox__nav gallery-lightbox__nav--prev" type="button" data-lightbox-prev aria-label="前の写真へ">‹</button>
    <figure class="gallery-lightbox__figure">
      <img data-lightbox-image src="" alt="" />
      <figcaption data-lightbox-caption></figcaption>
    </figure>
    <button class="gallery-lightbox__nav gallery-lightbox__nav--next" type="button" data-lightbox-next aria-label="次の写真へ">›</button>
  </div>

  <section class="cta-section" aria-labelledby="works-contact-title">
    <div data-animate="fade-up">
      <p class="eyebrow">Contact</p>
      <h2 id="works-contact-title">気になる写真の雰囲気を、LINEで教えてください。</h2>
      <p>「この写真みたいに撮りたい」「場所はまだ未定」でも大丈夫です。写真を見ながら相談できます。</p>
    </div>
    <div class="cta-section__actions" data-animate="fade-up">
      <a class="button button--light" href={siteLinks.line} target="_blank" rel="noreferrer">LINEで相談する</a>
      <a class="button button--ghost" href="/price/">料金を見る</a>
    </div>
  </section>

  <script is:inline>
    (() => {
      const lightbox = document.querySelector("[data-lightbox]");
      const lightboxImage = document.querySelector("[data-lightbox-image]");
      const caption = document.querySelector("[data-lightbox-caption]");
      const closeButton = document.querySelector("[data-lightbox-close]");
      const prevButton = document.querySelector("[data-lightbox-prev]");
      const nextButton = document.querySelector("[data-lightbox-next]");
      const triggers = Array.from(document.querySelectorAll("[data-lightbox-trigger]"));

      if (!lightbox || !lightboxImage || !caption || !closeButton || !prevButton || !nextButton || triggers.length === 0) {
        return;
      }

      let currentIndex = 0;
      let pointerStartX = 0;

      const showImage = (index) => {
        currentIndex = (index + triggers.length) % triggers.length;
        const sourceImage = triggers[currentIndex].querySelector("img");

        if (!sourceImage) {
          return;
        }

        lightboxImage.src = sourceImage.currentSrc || sourceImage.src;
        lightboxImage.alt = sourceImage.alt;
        caption.textContent = sourceImage.alt;
      };

      const openLightbox = (index) => {
        showImage(index);
        lightbox.hidden = false;
        lightbox.setAttribute("aria-hidden", "false");
        document.body.classList.add("is-lightbox-open");
        closeButton.focus();
      };

      const closeLightbox = () => {
        lightbox.hidden = true;
        lightbox.setAttribute("aria-hidden", "true");
        document.body.classList.remove("is-lightbox-open");
        triggers[currentIndex]?.focus();
      };

      triggers.forEach((trigger, index) => {
        trigger.addEventListener("click", () => openLightbox(index));
      });

      closeButton.addEventListener("click", closeLightbox);
      prevButton.addEventListener("click", () => showImage(currentIndex - 1));
      nextButton.addEventListener("click", () => showImage(currentIndex + 1));

      lightbox.addEventListener("click", (event) => {
        if (event.target === lightbox) {
          closeLightbox();
        }
      });

      lightbox.addEventListener("pointerdown", (event) => {
        pointerStartX = event.clientX;
      });

      lightbox.addEventListener("pointerup", (event) => {
        const swipeDistance = event.clientX - pointerStartX;

        if (Math.abs(swipeDistance) < 48) {
          return;
        }

        showImage(currentIndex + (swipeDistance < 0 ? 1 : -1));
      });

      document.addEventListener("keydown", (event) => {
        if (lightbox.hidden) {
          return;
        }

        if (event.key === "Escape") {
          closeLightbox();
        }

        if (event.key === "ArrowLeft") {
          showImage(currentIndex - 1);
        }

        if (event.key === "ArrowRight") {
          showImage(currentIndex + 1);
        }
      });
    })();
  </script>
</BaseLayout>
