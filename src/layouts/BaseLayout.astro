---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { siteContent } from "../data/siteContent";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = siteContent.meta.title,
  description = siteContent.meta.description,
  image = "/ogp/asaka-photography-og.jpg",
  noindex = false,
} = Astro.props;
const configuredSite =
  import.meta.env.PUBLIC_SITE_URL ?? Astro.site?.toString() ?? "https://asaka-photography.example.com";
const canonicalUrl = new URL(Astro.url.pathname, configuredSite).toString();
const ogImageUrl = new URL(image, configuredSite).toString();
const clarityProjectId = import.meta.env.PUBLIC_CLARITY_PROJECT_ID;
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? "G-KCDDX4Y6VP";
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="ASAKA Photography" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="夕日のすすき野で寄り添う新郎新婦の写真" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {
      clarityProjectId && (
        <script is:inline define:vars={{ clarityProjectId }}>
          (function (c, l, a, r, i, t, y) {
            c[a] =
              c[a] ||
              function () {
                (c[a].q = c[a].q || []).push(arguments);
              };
            t = l.createElement(r);
            t.async = 1;
            t.src = "https://www.clarity.ms/tag/" + i;
            y = l.getElementsByTagName(r)[0];
            y.parentNode.insertBefore(t, y);
          })(window, document, "clarity", "script", clarityProjectId);
        </script>
      )
    }
    {
      gaMeasurementId && (
        <>
          <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
          <script is:inline define:vars={{ gaMeasurementId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", gaMeasurementId);
          </script>
        </>
      )
    }
    <script is:inline>
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.documentElement.classList.add("motion-ready");
      }
    </script>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      const analyticsWindow = window as Window & {
        clarity?: (eventType: string, eventName: string) => void;
        gtag?: (...args: unknown[]) => void;
      };
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const targets = Array.from(document.querySelectorAll<HTMLElement>("[data-animate]"));
      const show = (target: HTMLElement) => target.classList.add("is-visible");
      const isInitiallyVisible = (target: HTMLElement) => {
        const rect = target.getBoundingClientRect();
        return rect.top < window.innerHeight * 0.96 && rect.bottom > 0;
      };

      if (reduceMotion || !("IntersectionObserver" in window)) {
        targets.forEach(show);
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                show(entry.target as HTMLElement);
                observer.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -12% 0px", threshold: 0.12 },
        );

        targets.forEach((target) => {
          if (isInitiallyVisible(target)) {
            show(target);
          } else {
            observer.observe(target);
          }
        });
      }

      document.querySelectorAll<HTMLAnchorElement>('a[href^="https://lin.ee/"]').forEach((link) => {
        link.addEventListener("click", () => {
          analyticsWindow.clarity?.("event", "line_cta_click");
          analyticsWindow.gtag?.("event", "line_cta_click", {
            event_category: "cta",
            event_label: window.location.pathname,
            link_text: link.textContent?.trim() ?? "LINE",
          });
        });
      });
    </script>
  </body>
</html>
